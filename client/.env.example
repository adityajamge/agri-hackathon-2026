VITE_APP_NAME=CropGuard
VITE_API_BASE_URL=http://localhost:3000/api

# External providers (frontend only when required)
VITE_WEATHER_BASE_URL=https://api.open-meteo.com/v1
VITE_PLANT_AI_ENDPOINT=https://api.plant.id/v2/identify
VITE_PLANT_AI_API_KEY=replace_with_plant_ai_key

# Map rendering
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Feature flags
VITE_ENABLE_COMMUNITY_ALERTS=true
VITE_ENABLE_OFFLINE_CACHE=true
