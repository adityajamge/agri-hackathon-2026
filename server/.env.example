PORT=3000
NODE_ENV=development

# Frontend origin
CORS_ORIGIN=http://localhost:5173,http://localhost,https://localhost,capacitor://localhost,ionic://localhost

# Database
DATABASE_URL=postgresql://username:password@host:5432/database

# Auth
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d

# External services
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
CROP_HEALTH_BASE_URL=https://crop.kindwise.com/api/v1
CROP_HEALTH_API_KEY=replace_with_crop_health_key
