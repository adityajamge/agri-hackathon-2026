PORT=3000
NODE_ENV=development

# Frontend origin
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cropguard

# Auth
JWT_SECRET=replace_with_secure_secret

# External services
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
PLANT_AI_ENDPOINT=https://api.plant.id/v2/identify
PLANT_AI_API_KEY=replace_with_plant_ai_key

# Notifications / optional services
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
